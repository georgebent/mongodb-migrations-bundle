{
    "name": "georgebent/mongodb-migrations-bundle",
    "description": "Symfony bundle for MongoDB migrations",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "George Bent",
            "email": "yur4ikkr@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-mongodb": "^2.2",
        "mongodb/mongodb": "^2.2",
        "symfony/config": "^8.0",
        "symfony/console": "^8.0",
        "symfony/dependency-injection": "^8.0",
        "symfony/http-kernel": "^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.93",
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "GeorgeBent\\MongodbMigrationsBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GeorgeBent\\MongodbMigrationsBundle\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs-check": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff",
        "cs-fix": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php",
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
